<%= form_with(model: [ post, comment ], id: "new_comment") do |form| %>
  <% if comment.errors.any? %>
    <div style="color: red">
      <% comment.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :body, "Add a comment", style: "display: block" %>
    <%= form.textarea :body, rows: 3, cols: 40 %>
  </div>

  <%= form.submit "Post comment" %>
<% end %>
